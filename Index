<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Retro 3D Tetris</title>
    <style>
        body {
            background-color: #222;
            color: #fff;
            font-family: 'Courier New', Courier, monospace;
            display: flex;
            flex-direction: column;
            align-items: center;
            margin: 0;
            padding: 20px;
            touch-action: none; /* 모바일에서 스와이프 방지 */
        }
        h1 { margin: 10px 0; font-size: 24px; text-shadow: 2px 2px #000; }
        #game-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            background: #333;
            padding: 15px;
            border-radius: 10px;
            box-shadow: 0 10px 20px rgba(0,0,0,0.5);
            border: 4px solid #555;
        }
        canvas {
            background-color: #111;
            border: 2px solid #888;
        }
        .info {
            display: flex;
            justify-content: space-between;
            width: 100%;
            margin-bottom: 10px;
            font-size: 18px;
            font-weight: bold;
        }
        /* 모바일 컨트롤 버튼 */
        .controls {
            display: flex;
            flex-direction: column;
            align-items: center;
            margin-top: 15px;
            gap: 10px;
        }
        .row { display: flex; gap: 10px; }
        .btn {
            background: #555;
            color: white;
            border: 2px solid #777;
            padding: 15px 20px;
            border-radius: 5px;
            font-size: 18px;
            font-weight: bold;
            cursor: pointer;
            user-select: none;
            box-shadow: 0 4px #222;
        }
        .btn:active {
            box-shadow: 0 0 #222;
            transform: translateY(4px);
        }
        
        /* PC에서는 컨트롤 버튼을 숨길 수 있지만, 직관성을 위해 유지하거나 미디어 쿼리로 조절 가능 */
        @media (min-width: 768px) {
            canvas { width: 300px; height: 600px; } /* PC에서 캔버스 크기 확대 */
        }
    </style>
</head>
<body>

    <h1>RETRO TETRIS</h1>
    <div id="game-container">
        <div class="info">
            <span>SCORE: <span id="score">0</span></span>
        </div>
        <canvas id="tetris" width="200" height="400"></canvas>
        
        <div class="controls">
            <button class="btn" id="btn-up">ROTATE (↑)</button>
            <div class="row">
                <button class="btn" id="btn-left">LEFT (←)</button>
                <button class="btn" id="btn-down">DOWN (↓)</button>
                <button class="btn" id="btn-right">RIGHT (→)</button>
            </div>
            <button class="btn" id="btn-drop" style="width: 100%;">HARD DROP (SPACE)</button>
        </div>
    </div>

<script>
    // --- 1. 기본 설정 및 변수 ---
    const canvas = document.getElementById('tetris');
    const ctx = canvas.getContext('2d');
    const scoreElement = document.getElementById('score');
    
    const ROWS = 20;
    const COLS = 10;
    const BLOCK_SIZE = 20; // 캔버스 너비(200) / COLS(10)
    
    let board = [];
    let score = 0;
    let dropCounter = 0;
    let dropInterval = 1000;
    let lastTime = 0;
    
    // 블록 색상 (CSS 색상 코드)
    const COLORS = [
        null,
        '#FF0D72', // T
        '#0DC2FF', // I
        '#0DFF72', // S
        '#F538FF', // Z
        '#FF8E0D', // L
        '#FFE138', // J
        '#3877FF'  // O
    ];

    // 테트로미노 모양 정의
    const SHAPES = [
        [],
        [[0, 1, 0], [1, 1, 1], [0, 0, 0]], // T
        [[0, 2, 0, 0], [0, 2, 0, 0], [0, 2, 0, 0], [0, 2, 0, 0]], // I
        [[0, 3, 3], [3, 3, 0], [0, 0, 0]], // S
        [[4, 4, 0], [0, 4, 4], [0, 0, 0]], // Z
        [[0, 5, 0], [0, 5, 0], [0, 5, 5]], // L
        [[0, 6, 0], [0, 6, 0], [6, 6, 0]], // J
        [[7, 7], [7, 7]] // O
    ];

    // 현재 플레이어가 조종하는 블록 객체
    const player = { pos: {x: 0, y: 0}, matrix: null };

    // --- 2. 사운드 시스템 (Web Audio API) ---
    const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    
    function playSound(type) {
        if (audioCtx.state === 'suspended') audioCtx.resume();
        const oscillator = audioCtx.createOscillator();
        const gainNode = audioCtx.createGain();
        
        oscillator.connect(gainNode);
        gainNode.connect(audioCtx.destination);
        
        oscillator.type = 'square'; // 레트로한 8비트 사운드 느낌
        
        if (type === 'move') {
            oscillator.frequency.setValueAtTime(300, audioCtx.currentTime);
            gainNode.gain.setValueAtTime(0.05, audioCtx.currentTime);
            oscillator.start();
            oscillator.stop(audioCtx.currentTime + 0.05);
        } else if (type === 'rotate') {
            oscillator.frequency.setValueAtTime(500, audioCtx.currentTime);
            gainNode.gain.setValueAtTime(0.05, audioCtx.currentTime);
            oscillator.start();
            oscillator.stop(audioCtx.currentTime + 0.05);
        } else if (type === 'drop') {
            oscillator.frequency.setValueAtTime(150, audioCtx.currentTime);
            oscillator.frequency.exponentialRampToValueAtTime(50, audioCtx.currentTime + 0.1);
            gainNode.gain.setValueAtTime(0.1, audioCtx.currentTime);
            oscillator.start();
            oscillator.stop(audioCtx.currentTime + 0.1);
        } else if (type === 'clear') {
            oscillator.frequency.setValueAtTime(600, audioCtx.currentTime);
            oscillator.frequency.setValueAtTime(800, audioCtx.currentTime + 0.1);
            gainNode.gain.setValueAtTime(0.1, audioCtx.currentTime);
            oscillator.start();
            oscillator.stop(audioCtx.currentTime + 0.2);
        }
    }

    // --- 3. 핵심 함수 ---
    // 게임 보드 초기화
    function createMatrix(w, h) {
        const matrix = [];
        while (h--) {
            matrix.push(new Array(w).fill(0));
        }
        return matrix;
    }

    // 입체적인 블록 그리기 (핵심 포인트)
    function draw3DBlock(x, y, color) {
        // 기본 바탕색
        ctx.fillStyle = color;
        ctx.fillRect(x * BLOCK_SIZE, y * BLOCK_SIZE, BLOCK_SIZE, BLOCK_SIZE);

        // 상단 및 좌측의 밝은 부분 (명암)
        ctx.fillStyle = 'rgba(255, 255, 255, 0.4)';
        ctx.beginPath();
        ctx.moveTo(x * BLOCK_SIZE, y * BLOCK_SIZE);
        ctx.lineTo((x + 1) * BLOCK_SIZE, y * BLOCK_SIZE);
        ctx.lineTo(x * BLOCK_SIZE + 4, y * BLOCK_SIZE + 4);
        ctx.lineTo(x * BLOCK_SIZE, (y + 1) * BLOCK_SIZE);
        ctx.fill();

        // 하단 및 우측의 어두운 부분 (명암)
        ctx.fillStyle = 'rgba(0, 0, 0, 0.4)';
        ctx.beginPath();
        ctx.moveTo((x + 1) * BLOCK_SIZE, y * BLOCK_SIZE);
        ctx.lineTo((x + 1) * BLOCK_SIZE, (y + 1) * BLOCK_SIZE);
        ctx.lineTo(x * BLOCK_SIZE, (y + 1) * BLOCK_SIZE);
        ctx.lineTo(x * BLOCK_SIZE + 4, y * BLOCK_SIZE + BLOCK_SIZE - 4);
        ctx.lineTo((x + 1) * BLOCK_SIZE - 4, (y + 1) * BLOCK_SIZE - 4);
        ctx.lineTo((x + 1) * BLOCK_SIZE - 4, y * BLOCK_SIZE + 4);
        ctx.fill();

        // 테두리
        ctx.strokeStyle = 'rgba(0,0,0,0.8)';
        ctx.strokeRect(x * BLOCK_SIZE, y * BLOCK_SIZE, BLOCK_SIZE, BLOCK_SIZE);
    }

    function drawMatrix(matrix, offset) {
        matrix.forEach((row, y) => {
            row.forEach((value, x) => {
                if (value !== 0) {
                    draw3DBlock(x + offset.x, y + offset.y, COLORS[value]);
                }
            });
        });
    }

    function draw() {
        ctx.fillStyle = '#111';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        drawMatrix(board, {x: 0, y: 0});
        drawMatrix(player.matrix, player.pos);
    }

    function collide(board, player) {
        const [m, o] = [player.matrix, player.pos];
        for (let y = 0; y < m.length; ++y) {
            for (let x = 0; x < m[y].length; ++x) {
                if (m[y][x] !== 0 &&
                   (board[y + o.y] && board[y + o.y][x + o.x]) !== 0) {
                    return true;
                }
            }
        }
        return false;
    }

    function merge(board, player) {
        player.matrix.forEach((row, y) => {
            row.forEach((value, x) => {
                if (value !== 0) {
                    board[y + player.pos.y][x + player.pos.x] = value;
                }
            });
        });
    }

    function rotate(matrix, dir) {
        for (let y = 0; y < matrix.length; ++y) {
            for (let x = 0; x < y; ++x) {
                [matrix[x][y], matrix[y][x]] = [matrix[y][x], matrix[x][y]];
            }
        }
        if (dir > 0) matrix.forEach(row => row.reverse());
        else matrix.reverse();
    }

    function playerDrop() {
        player.pos.y++;
        if (collide(board, player)) {
            player.pos.y--;
            merge(board, player);
            playerReset();
            boardSweep();
            playSound('drop');
        }
        dropCounter = 0;
    }

    function playerHardDrop() {
        while (!collide(board, player)) {
            player.pos.y++;
        }
        player.pos.y--;
        merge(board, player);
        playerReset();
        boardSweep();
        playSound('drop');
        dropCounter = 0;
    }

    function playerMove(dir) {
        player.pos.x += dir;
        if (collide(board, player)) {
            player.pos.x -= dir;
        } else {
            playSound('move');
        }
    }

    function playerRotate() {
        const pos = player.pos.x;
        let offset = 1;
        rotate(player.matrix, 1);
        while (collide(board, player)) {
            player.pos.x += offset;
            offset = -(offset + (offset > 0 ? 1 : -1));
            if (offset > player.matrix[0].length) {
                rotate(player.matrix, -1);
                player.pos.x = pos;
                return;
            }
        }
        playSound('rotate');
    }

    function playerReset() {
        const pieces = [1, 2, 3, 4, 5, 6, 7];
        const randomPiece = pieces[Math.floor(Math.random() * pieces.length)];
        // 2차원 배열 깊은 복사
        player.matrix = SHAPES[randomPiece].map(row => [...row]); 
        player.pos.y = 0;
        player.pos.x = Math.floor(COLS / 2) - Math.floor(player.matrix[0].length / 2);
        
        // 게임 오버 체크
        if (collide(board, player)) {
            board.forEach(row => row.fill(0));
            score = 0;
            updateScore();
        }
    }

    function boardSweep() {
        let rowCount = 1;
        outer: for (let y = board.length - 1; y >= 0; --y) {
            for (let x = 0; x < board[y].length; ++x) {
                if (board[y][x] === 0) continue outer;
            }
            const row = board.splice(y, 1)[0].fill(0);
            board.unshift(row);
            ++y;
            score += rowCount * 100;
            rowCount *= 2;
            playSound('clear');
        }
        updateScore();
    }

    function updateScore() {
        scoreElement.innerText = score;
        // 점수가 오를수록 속도 증가
        dropInterval = Math.max(100, 1000 - (score * 0.5)); 
    }

    // --- 4. 게임 루프 ---
    function update(time = 0) {
        const deltaTime = time - lastTime;
        lastTime = time;
        dropCounter += deltaTime;
        
        if (dropCounter > dropInterval) {
            playerDrop();
        }
        draw();
        requestAnimationFrame(update);
    }

    // --- 5. 컨트롤 이벤트 리스너 ---
    document.addEventListener('keydown', event => {
        if (event.keyCode === 37) playerMove(-1); // Left
        else if (event.keyCode === 39) playerMove(1); // Right
        else if (event.keyCode === 40) playerDrop(); // Down
        else if (event.keyCode === 38) playerRotate(); // Up
        else if (event.keyCode === 32) playerHardDrop(); // Space
    });

    // 모바일 터치 & 마우스 클릭 이벤트 바인딩 함수
    function bindButton(id, action) {
        const btn = document.getElementById(id);
        const trigger = (e) => { e.preventDefault(); action(); };
        btn.addEventListener('touchstart', trigger, {passive: false});
        btn.addEventListener('mousedown', trigger);
    }

    bindButton('btn-left', () => playerMove(-1));
    bindButton('btn-right', () => playerMove(1));
    bindButton('btn-down', () => playerDrop());
    bindButton('btn-up', () => playerRotate());
    bindButton('btn-drop', () => playerHardDrop());

    // 초기화 및 실행
    board = createMatrix(COLS, ROWS);
    playerReset();
    updateScore();
    update();

</script>
</body>
</html>
